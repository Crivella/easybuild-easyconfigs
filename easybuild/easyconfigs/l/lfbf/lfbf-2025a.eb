easyblock = 'Toolchain'

name = 'lfbf'
version = '2025a'

homepage = '(none)'
description = """GNU Compiler Collection (GCC) based compiler toolchain, including
 FlexiBLAS (BLAS and LAPACK support) and (serial) FFTW."""

toolchain = SYSTEM

local_llvmver = '20.1.0'

dependencies = [
    ('LLVM', local_llvmver),
    ('FlexiBLAS', '3.4.4', '', ('LLVMtc', local_llvmver)),
    ('FFTW', '3.3.10', '', ('LLVMtc', local_llvmver)),
]

moduleclass = 'toolchain'
