easyblock = 'Toolchain'

name = 'lompi'
version = '2024a'

homepage = '(none)'
description = """GNU Compiler Collection (GCC) based compiler toolchain,
 including OpenMPI for MPI support."""

toolchain = SYSTEM

local_llvmver = '19.1.1'

# compiler toolchain dependencies
dependencies = [
    ('LLVMtc', local_llvmver),  # includes both GCC and binutils
    ('OpenMPI', '5.0.3', '', ('LLVMtc', local_llvmver)),
]

moduleclass = 'toolchain'
